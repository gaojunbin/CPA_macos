ObjC.import("Cocoa");
ObjC.import("Foundation");

var app = Application.currentApplication();
app.includeStandardAdditions = true;

var nsApp = $.NSApplication.sharedApplication;
var statusItem = null;
var statusMenu = null;
var delegate = null;
var refreshTimer = null;
var keychainService = "local.cpa.quota-bar";
var keychainAccount = "management-key";
var settings = loadSettings();
var snapshot = null;
var refreshing = false;
var lastError = "";
var started = false;
var antigravityDefaultProjectID = "bamboo-precept-lgxtn";
var antigravityModelURLs = [
  "https://daily-cloudcode-pa.googleapis.com/v1internal:fetchAvailableModels",
  "https://daily-cloudcode-pa.sandbox.googleapis.com/v1internal:fetchAvailableModels",
  "https://cloudcode-pa.googleapis.com/v1internal:fetchAvailableModels"
];
var antigravityGroups = [
  { id: "claude-gpt", label: "Claude/GPT", identifiers: ["claude-sonnet-4-6", "claude-opus-4-6-thinking", "gpt-oss-120b-medium"] },
  { id: "gemini-3-pro", label: "Gemini 3 Pro", identifiers: ["gemini-3-pro-high", "gemini-3-pro-low"] },
  { id: "gemini-3-1-pro-series", label: "Gemini 3.1 Pro Series", identifiers: ["gemini-3.1-pro-high", "gemini-3.1-pro-low"] },
  { id: "gemini-2-5-flash", label: "Gemini 2.5 Flash", identifiers: ["gemini-2.5-flash", "gemini-2.5-flash-thinking"] },
  { id: "gemini-2-5-flash-lite", label: "Gemini 2.5 Flash Lite", identifiers: ["gemini-2.5-flash-lite"] },
  { id: "gemini-2-5-cu", label: "Gemini 2.5 CU", identifiers: ["rev19-uic3-1p"] },
  { id: "gemini-3-flash", label: "Gemini 3 Flash", identifiers: ["gemini-3-flash"] },
  { id: "gemini-image", label: "gemini-3.1-flash-image", identifiers: ["gemini-3.1-flash-image"], labelFromModel: true }
];

ObjC.registerSubclass({
  name: "CPAQuotaBarDelegate",
  protocols: ["NSApplicationDelegate"],
  methods: {
    "applicationDidFinishLaunching:": {
      types: ["void", ["id"]],
      implementation: function () {
        startApp();
      }
    },
    "refresh:": {
      types: ["void", ["id"]],
      implementation: function () {
        refreshQuotas(true);
      }
    },
    "settings:": {
      types: ["void", ["id"]],
      implementation: function () {
        showSettings();
      }
    },
    "quit:": {
      types: ["void", ["id"]],
      implementation: function () {
        nsApp.terminate(null);
      }
    },
    "timerRefresh:": {
      types: ["void", ["id"]],
      implementation: function () {
        refreshQuotas(false);
      }
    }
  }
});

delegate = $.CPAQuotaBarDelegate.alloc.init;
nsApp.delegate = delegate;
nsApp.setActivationPolicy($.NSApplicationActivationPolicyAccessory);
startApp();
nsApp.run;

function startApp() {
  if (started) return;
  started = true;
  setupStatusBar();
  if (!isConfigured()) {
    updateMenu();
    showSettings();
  } else {
    refreshQuotas(false);
    restartTimer();
  }
}

function setupStatusBar() {
  statusItem = $.NSStatusBar.systemStatusBar.statusItemWithLength($.NSVariableStatusItemLength);
  var button = statusItem.button;
  button.title = "";
  var image = $.NSImage.imageWithSystemSymbolNameAccessibilityDescription("gauge.with.dots.needle.50percent", "CLIProxyAPI quota");
  if (image) {
    button.image = image;
    button.imagePosition = $.NSImageLeft;
  }
  statusMenu = $.NSMenu.alloc.initWithTitle("Pool");
  statusItem.menu = statusMenu;
  updateMenu();
}

function updateStatusTitle() {
  if (!statusItem) return;
  var button = statusItem.button;
  if (!isConfigured()) {
    button.title = "";
    return;
  }
  if (refreshing && !snapshot) {
    button.title = "  ⋯";
  } else if (lastError && !snapshot) {
    button.title = "  !";
  } else if (snapshot && typeof snapshot.primaryAverage === "number") {
    button.title = "  " + formatPercent(snapshot.primaryAverage);
  } else {
    button.title = "";
  }
}

function updateMenu() {
  if (!statusMenu) return;
  statusMenu.removeAllItems;

  if (snapshot) {
    snapshot.relativeUpdate = relativeUpdateString(snapshot.updatedAt);
  }

  if (!isConfigured()) {
    addDisabledItem("Not configured");
    statusMenu.addItem($.NSMenuItem.separatorItem);
    addDisabledItem("Open Settings to connect.");
  } else if (lastError && !snapshot) {
    addDisabledItem(trimForMenu(lastError, 72));
  } else if (snapshot) {
    addDisabledItem(formatPercent(snapshot.primaryAverage) + " · 5h    " +
      formatPercent(snapshot.weeklyAverage) + " · 7d    " +
      snapshot.quotaAccounts + "/" + snapshot.totalAccounts + " accts");
    addDisabledItem("Updated " + snapshot.relativeUpdate);
    statusMenu.addItem($.NSMenuItem.separatorItem);

    if (snapshot.accounts.length === 0) {
      addDisabledItem("No monitored accounts");
    } else {
      snapshot.accounts.forEach(function (account) {
        var p5 = account.primaryRemaining;
        var p7 = account.weeklyRemaining;
        var dot = statusGlyph(account);
        var name = trimForMenu(account.name, 26);
        var title = "";
        if (account.quotaRows && account.quotaRows.length) {
          title = dot + "  " + padRight(name, 26) + "   " +
            padLeft(String(account.quotaRows.length), 2) + " quota rows";
        } else {
          title = dot + "  " + padRight(name, 26) + "   " +
            padLeft(formatPercent(p5), 5) + "   " +
            padLeft(formatPercent(p7), 5);
        }
        if (account.plan) title += "   " + account.plan;
        addDisabledItem(title);
        if (account.quotaRows && account.quotaRows.length) {
          account.quotaRows.forEach(function (row) {
            var value = row.displayValue || formatPercent(row.remaining);
            var amount = row.amount ? "   " + padRight(trimForMenu(row.amount, 16), 16) : "";
            addDisabledItem("     " +
              padRight(trimForMenu(row.label, 24), 24) + "   " +
              padLeft(value, 5) + amount + "   " +
              trimForMenu(row.resetLabel || "-", 11));
          });
        }
        if (account.error) addDisabledItem("     " + trimForMenu(account.error, 72));
      });
    }
    if (lastError) {
      statusMenu.addItem($.NSMenuItem.separatorItem);
      addDisabledItem(trimForMenu(lastError, 72));
    }
  } else {
    addDisabledItem(refreshing ? "Refreshing…" : "No data");
  }

  statusMenu.addItem($.NSMenuItem.separatorItem);
  addActionItem(refreshing ? "Refreshing…" : "Refresh", "refresh:", !refreshing && isConfigured());
  addActionItem("Settings…", "settings:", true);
  addActionItem("Quit", "quit:", true);
  updateStatusTitle();
}

function addDisabledItem(title) {
  var item = $.NSMenuItem.alloc.initWithTitleActionKeyEquivalent(String(title), null, "");
  item.enabled = false;
  statusMenu.addItem(item);
}

function addActionItem(title, actionName, enabled) {
  var item = $.NSMenuItem.alloc.initWithTitleActionKeyEquivalent(String(title), $.NSSelectorFromString(actionName), "");
  item.target = delegate;
  item.enabled = enabled;
  statusMenu.addItem(item);
}

function showSettings() {
  var alert = $.NSAlert.alloc.init;
  alert.messageText = "CLIProxyAPI";
  alert.informativeText = "Where to reach your pool.";
  alert.addButtonWithTitle("Save");
  alert.addButtonWithTitle("Cancel");

  var stack = $.NSStackView.alloc.initWithFrame($.NSMakeRect(0, 0, 420, 190));
  stack.orientation = $.NSUserInterfaceLayoutOrientationVertical;
  stack.spacing = 8;

  var urlField = $.NSTextField.alloc.initWithFrame($.NSMakeRect(0, 0, 420, 28));
  urlField.placeholderString = "https://your-vps.example.com";
  urlField.stringValue = settings.baseURL || "http://127.0.0.1:8317";

  var keyField = $.NSSecureTextField.alloc.initWithFrame($.NSMakeRect(0, 0, 420, 28));
  keyField.placeholderString = "Management password";
  keyField.stringValue = settings.managementKey || "";

  var intervalField = $.NSTextField.alloc.initWithFrame($.NSMakeRect(0, 0, 420, 28));
  intervalField.placeholderString = "5";
  intervalField.stringValue = String(Math.max(1, Math.round((settings.refreshIntervalSeconds || 300) / 60)));

  stack.addArrangedSubview(labelField("Endpoint"));
  stack.addArrangedSubview(urlField);
  stack.addArrangedSubview(labelField("Password"));
  stack.addArrangedSubview(keyField);
  stack.addArrangedSubview(labelField("Refresh (minutes)"));
  stack.addArrangedSubview(intervalField);
  alert.accessoryView = stack;

  nsApp.activateIgnoringOtherApps(true);
  var result = alert.runModal;
  if (result !== $.NSAlertFirstButtonReturn) return;

  var minutes = parseFloat(ObjC.unwrap(intervalField.stringValue)) || 5;
  settings = {
    baseURL: ObjC.unwrap(urlField.stringValue),
    managementKey: ObjC.unwrap(keyField.stringValue),
    refreshIntervalSeconds: Math.max(60, Math.min(86400, minutes * 60))
  };
  saveSettings(settings);
  lastError = "";
  updateMenu();
  refreshQuotas(true);
  restartTimer();
}

function labelField(text) {
  var field = $.NSTextField.labelWithString(String(text));
  field.font = $.NSFont.systemFontOfSize(11);
  field.textColor = $.NSColor.secondaryLabelColor;
  return field;
}

function restartTimer() {
  if (refreshTimer) {
    refreshTimer.invalidate;
    refreshTimer = null;
  }
  if (!isConfigured()) return;
  refreshTimer = $.NSTimer.scheduledTimerWithTimeIntervalTargetSelectorUserInfoRepeats(
    settings.refreshIntervalSeconds || 300,
    delegate,
    $.NSSelectorFromString("timerRefresh:"),
    null,
    true
  );
}

function refreshQuotas(showErrors) {
  if (refreshing || !isConfigured()) {
    updateMenu();
    return;
  }
  refreshing = true;
  lastError = "";
  updateMenu();

  try {
    var authFiles = fetchAuthFiles().filter(function (auth) {
      return auth.isCodexLike || auth.isAntigravity || auth.isClaude || auth.isKimi || auth.isXAI;
    });
    var accounts = authFiles.map(function (auth) {
      return fetchAccountQuota(auth);
    });
    snapshot = buildSnapshot(accounts);
  } catch (error) {
    lastError = String(error);
    if (showErrors) showError(lastError);
  }

  refreshing = false;
  updateMenu();
}

function fetchAuthFiles() {
  var raw = curlJSON("GET", managementURL("/v0/management/auth-files"), null);
  var payload = JSON.parse(raw || "{}");
  var files = Array.isArray(payload.files) ? payload.files : [];
  return files.map(normalizeAuthFile);
}

function fetchAccountQuota(auth) {
  if (auth.isAntigravity) return fetchAntigravityQuota(auth);
  if (auth.isClaude) return fetchClaudeQuota(auth);
  if (auth.isKimi) return fetchKimiQuota(auth);
  if (auth.isXAI) return fetchXAIQuota(auth);

  if (!auth.authIndex) {
    auth.error = "missing auth_index";
    return auth;
  }
  if (auth.disabled) {
    auth.error = "";
    return auth;
  }

  var headers = {
    "Authorization": "Bearer $TOKEN$",
    "Accept": "application/json",
    "Content-Type": "application/json",
    "User-Agent": "codex_cli_rs/0.76.0 (Macintosh; arm64) CPAQuotaBar/1.0"
  };
  if (auth.accountID) headers["ChatGPT-Account-Id"] = auth.accountID;

  var payload = {
    auth_index: auth.authIndex,
    method: "GET",
    url: "https://chatgpt.com/backend-api/wham/usage",
    header: headers
  };

  try {
    var raw = curlJSON("POST", managementURL("/v0/management/api-call"), JSON.stringify(payload));
    var envelope = JSON.parse(raw || "{}");
    var body = typeof envelope.body === "string" ? envelope.body : JSON.stringify(envelope.body || {});
    var usage = parseUsage(body);
    auth.primaryRemaining = usage.primaryRemaining;
    auth.weeklyRemaining = usage.weeklyRemaining;
    auth.primaryReset = usage.primaryReset;
    auth.weeklyReset = usage.weeklyReset;
    auth.plan = usage.plan || auth.plan;
    auth.error = "";
  } catch (error) {
    auth.error = String(error);
  }
  return auth;
}

function apiCallEnvelope(auth, method, url, headers, data) {
  var payload = {
    auth_index: auth.authIndex,
    method: method,
    url: url,
    header: headers || {}
  };
  if (data !== undefined && data !== null) payload.data = data;
  var raw = curlJSON("POST", managementURL("/v0/management/api-call"), JSON.stringify(payload));
  var envelope = JSON.parse(raw || "{}");
  var status = Number(envelope.status_code || envelope.statusCode || 0);
  var body = typeof envelope.body === "string" ? envelope.body : JSON.stringify(envelope.body || {});
  if (status < 200 || status >= 300) throw new Error(body || ("HTTP " + status));
  return body;
}

function fetchAntigravityQuota(auth) {
  if (!auth.authIndex) {
    auth.error = "missing auth_index";
    return auth;
  }
  if (auth.disabled) {
    auth.error = "";
    return auth;
  }

  try {
    var projectID = auth.projectID || antigravityDefaultProjectID;
    var usage = null;
    var lastBody = "";
    for (var i = 0; i < antigravityModelURLs.length; i++) {
      var payload = {
        auth_index: auth.authIndex,
        method: "POST",
        url: antigravityModelURLs[i],
        header: {
          "Authorization": "Bearer $TOKEN$",
          "Content-Type": "application/json",
          "User-Agent": "antigravity/1.21.9 darwin/arm64"
        },
        data: JSON.stringify({ project: projectID })
      };
      var raw = curlJSON("POST", managementURL("/v0/management/api-call"), JSON.stringify(payload));
      var envelope = JSON.parse(raw || "{}");
      var status = Number(envelope.status_code || envelope.statusCode || 0);
      var body = typeof envelope.body === "string" ? envelope.body : JSON.stringify(envelope.body || {});
      if (status < 200 || status >= 300) {
        lastBody = body;
        continue;
      }
      usage = parseAntigravityUsage(body);
      if (usage.quotaRows.length) break;
    }
    if (!usage) throw new Error(lastBody || "Antigravity quota unavailable");
    auth.quotaRows = usage.quotaRows;
    auth.error = "";
  } catch (error) {
    auth.error = String(error);
  }
  return auth;
}

function fetchClaudeQuota(auth) {
  if (!auth.authIndex) {
    auth.error = "missing auth_index";
    return auth;
  }
  if (auth.disabled) {
    auth.error = "";
    return auth;
  }
  var headers = {
    "Authorization": "Bearer $TOKEN$",
    "Content-Type": "application/json",
    "anthropic-beta": "oauth-2025-04-20"
  };
  try {
    var usage = apiCallEnvelope(auth, "GET", "https://api.anthropic.com/api/oauth/usage", headers, null);
    var profile = "{}";
    try {
      profile = apiCallEnvelope(auth, "GET", "https://api.anthropic.com/api/oauth/profile", headers, null);
    } catch (_) {}
    var parsed = parseClaudeUsage(usage, profile);
    auth.quotaRows = parsed.quotaRows;
    auth.plan = parsed.plan || auth.plan;
    auth.error = "";
  } catch (error) {
    auth.error = String(error);
  }
  return auth;
}

function fetchKimiQuota(auth) {
  if (!auth.authIndex) {
    auth.error = "missing auth_index";
    return auth;
  }
  if (auth.disabled) {
    auth.error = "";
    return auth;
  }
  try {
    var body = apiCallEnvelope(auth, "GET", "https://api.kimi.com/coding/v1/usages", {
      "Authorization": "Bearer $TOKEN$"
    }, null);
    auth.quotaRows = parseKimiUsage(body).quotaRows;
    auth.error = "";
  } catch (error) {
    auth.error = String(error);
  }
  return auth;
}

function fetchXAIQuota(auth) {
  if (!auth.authIndex) {
    auth.error = "missing auth_index";
    return auth;
  }
  if (auth.disabled) {
    auth.error = "";
    return auth;
  }
  try {
    var body = apiCallEnvelope(auth, "GET", "https://cli-chat-proxy.grok.com/v1/billing", {
      "Authorization": "Bearer $TOKEN$"
    }, null);
    auth.quotaRows = parseXAIUsage(body).quotaRows;
    auth.error = "";
  } catch (error) {
    auth.error = String(error);
  }
  return auth;
}

function curlJSON(method, url, body) {
  var command = "/usr/bin/curl -sS --fail-with-body --max-time 45 " +
    "-X " + shellQuote(method) + " " +
    "-H " + shellQuote("Authorization: Bearer " + settings.managementKey) + " " +
    "-H " + shellQuote("Content-Type: application/json") + " ";
  if (body !== null && body !== undefined) {
    command += "--data-binary " + shellQuote(body) + " ";
  }
  command += shellQuote(url);
  return app.doShellScript(command);
}

function normalizeAuthFile(file) {
  var provider = clean(file.provider || file.type || "");
  var idToken = file.id_token || {};
  var name = clean(file.label || file.email || file.account || cleanName(file.name) || file.id || "unknown");
  return {
    id: clean(file.id || file.name || name),
    name: name,
    authIndex: clean(file.auth_index || file.authIndex || ""),
    provider: provider,
    isCodexLike: provider === "codex" || provider.indexOf("openai") >= 0,
    isAntigravity: provider === "antigravity",
    isClaude: provider === "claude" || provider === "anthropic",
    isKimi: provider === "kimi",
    isXAI: provider === "xai" || provider === "x-ai" || provider === "grok",
    accountID: clean(idToken.chatgpt_account_id || file.chatgpt_account_id || file.account_id || ""),
    plan: clean(idToken.plan_type || file.plan_type || file.plan || ""),
    projectID: clean(file.project_id || file.projectId || ""),
    disabled: !!file.disabled || String(file.status || "").toLowerCase() === "disabled",
    primaryRemaining: null,
    weeklyRemaining: null,
    primaryReset: null,
    weeklyReset: null,
    balanceValue: null,
    balanceProgress: null,
    balanceLabel: "",
    balanceDetail: "",
    balanceUsable: null,
    quotaRows: [],
    error: ""
  };
}

function parseUsage(body) {
  var payload = JSON.parse(body || "{}");
  var rate = findRateLimit(payload);
  if (!rate) throw new Error("quota payload missing rate_limit");
  var primary = rate.primary_window || rate.primaryWindow || null;
  var secondary = rate.secondary_window || rate.secondaryWindow || null;
  var windows = pickWindows(primary, secondary);
  return {
    plan: clean(payload.plan_type || payload.planType || (payload.account_plan || {}).plan_type || ""),
    primaryRemaining: remainingPercent(windows.primary, rate),
    weeklyRemaining: remainingPercent(windows.weekly, rate),
    primaryReset: resetSeconds(windows.primary),
    weeklyReset: resetSeconds(windows.weekly)
  };
}

function parseAntigravityUsage(body) {
  var payload = JSON.parse(body || "{}");
  var models = payload.models || payload.modelQuotas || payload.model_quotas || {};
  if (!models || typeof models !== "object" || Array.isArray(models)) {
    throw new Error("quota payload missing models");
  }
  return { quotaRows: buildAntigravityRows(models) };
}

function parseClaudeUsage(usageBody, profileBody) {
  var payload = JSON.parse(usageBody || "{}");
  var profile = JSON.parse(profileBody || "{}");
  var defs = [
    ["five_hour", "5 小时限额"],
    ["seven_day", "7 天限额"],
    ["seven_day_oauth_apps", "7 天 OAuth 应用"],
    ["seven_day_opus", "7 天 Opus"],
    ["seven_day_sonnet", "7 天 Sonnet"],
    ["seven_day_cowork", "7 天 Cowork"],
    ["iguana_necktie", "Iguana Necktie"]
  ];
  var rows = [];
  defs.forEach(function (def) {
    var raw = payload[def[0]];
    if (!raw || typeof raw !== "object" || raw.utilization === undefined) return;
    var used = numberOrNull(raw.utilization);
    var remaining = used === null ? null : Math.max(0, Math.min(100, 100 - used));
    rows.push({
      label: def[1],
      remaining: remaining,
      displayValue: formatPercent(remaining),
      resetLabel: formatResetTime(raw.resets_at || raw.resetsAt || "")
    });
  });
  var extra = payload.extra_usage || payload.extraUsage || null;
  if (extra && (extra.is_enabled || extra.isEnabled)) {
    rows.push({
      label: "额外用量",
      remaining: null,
      displayValue: "--",
      amount: moneyPair(
        extra.used_credits !== undefined ? extra.used_credits : extra.usedCredits,
        extra.monthly_limit !== undefined ? extra.monthly_limit : extra.monthlyLimit
      ),
      resetLabel: "-"
    });
  }
  return { quotaRows: rows, plan: claudePlan(profile) };
}

function parseKimiUsage(body) {
  var payload = JSON.parse(body || "{}");
  var rows = [];
  if (payload.usage && typeof payload.usage === "object") {
    var summary = kimiRow(payload.usage, "周限额");
    if (summary) rows.push(summary);
  }
  var limits = Array.isArray(payload.limits) ? payload.limits : [];
  limits.forEach(function (item, index) {
    var raw = item && typeof item.detail === "object" ? item.detail : item;
    if (!raw || typeof raw !== "object") return;
    var row = kimiRow(raw, kimiLimitLabel(item || {}, raw, index));
    if (row) rows.push(row);
  });
  return { quotaRows: rows };
}

function parseXAIUsage(body) {
  var payload = JSON.parse(body || "{}");
  var config = payload.config || {};
  var limit = centsValue(config.monthlyLimit !== undefined ? config.monthlyLimit : config.monthly_limit);
  var used = centsValue(config.used);
  var cap = centsValue(config.onDemandCap !== undefined ? config.onDemandCap : config.on_demand_cap);
  var rows = [{
    label: "按量付费",
    remaining: null,
    displayValue: cap > 0 ? "已启用" : "未启用",
    amount: cap > 0 ? "封顶 " + money(cap) : "",
    resetLabel: "-"
  }];
  var remaining = null;
  if (limit > 0 && used !== null) remaining = Math.max(0, Math.min(100, 100 - used / limit * 100));
  rows.push({
    label: "月度积分",
    remaining: remaining,
    displayValue: formatPercent(remaining),
    amount: moneyPair(used, limit),
    resetLabel: formatResetTime(config.billingPeriodEnd || config.billing_period_end || "")
  });
  return { quotaRows: rows };
}

function claudePlan(profile) {
  var account = profile.account || {};
  if (account.has_claude_max) return "Max";
  if (account.has_claude_pro) return "专业版";
  var organization = profile.organization || {};
  if (String(organization.organization_type || "").toLowerCase() === "claude_team" &&
      String(organization.subscription_status || "").toLowerCase() === "active") {
    return "团队版";
  }
  if (account.has_claude_max === false && account.has_claude_pro === false) return "免费版";
  return "";
}

function kimiRow(raw, fallbackLabel) {
  var limit = integerOrNull(raw.limit);
  var used = integerOrNull(raw.used);
  if (used === null && limit !== null) {
    var remainingAmount = integerOrNull(raw.remaining);
    if (remainingAmount !== null) used = Math.max(0, limit - remainingAmount);
  }
  if (used === null && limit === null) return null;
  var remaining = null;
  if (limit > 0) remaining = Math.max(0, Math.min(100, (limit - (used || 0)) / limit * 100));
  else if ((used || 0) > 0) remaining = 0;
  return {
    label: clean(raw.name || raw.title || raw.scope || fallbackLabel),
    remaining: remaining,
    displayValue: formatPercent(remaining),
    amount: limit > 0 ? String(used || 0) + " / " + String(limit) : "",
    resetLabel: kimiResetHint(raw)
  };
}

function kimiLimitLabel(item, raw, index) {
  var named = clean(item.name || item.title || item.scope || raw.name || raw.title || raw.scope || "");
  if (named) return named;
  var window = item.window || {};
  var duration = integerOrNull(window.duration || item.duration || raw.duration);
  var unit = clean(window.timeUnit || window.time_unit || item.timeUnit || raw.timeUnit).toUpperCase();
  if (duration && duration > 0) return kimiDuration(duration, unit) + " 限额";
  return "限额 #" + (index + 1);
}

function kimiDuration(duration, unit) {
  if (unit === "MINUTES") return duration % 60 === 0 ? String(duration / 60) + "h" : String(duration) + "m";
  if (unit === "HOURS") return String(duration) + "h";
  if (unit === "DAYS") return String(duration) + "d";
  return String(duration) + "s";
}

function kimiResetHint(raw) {
  var keys = ["reset_at", "resetAt", "reset_time", "resetTime"];
  for (var i = 0; i < keys.length; i++) {
    var value = raw[keys[i]];
    if (!value) continue;
    var date = new Date(value);
    if (Number.isFinite(date.getTime())) return durationLabel((date.getTime() - Date.now()) / 1000) + " 后重置";
  }
  var seconds = numberOrNull(raw.reset_in || raw.resetIn || raw.ttl);
  return seconds && seconds > 0 ? durationLabel(seconds) + " 后重置" : "-";
}

function buildAntigravityRows(models) {
  var rows = [];
  var byID = {};
  antigravityGroups.forEach(function (group) { byID[group.id] = group; });

  function append(id, resetOverride) {
    var group = byID[id];
    if (!group) return null;
    var parsed = parseAntigravityGroup(group, models, resetOverride);
    if (parsed) rows.push(parsed.row);
    return parsed;
  }

  append("claude-gpt");
  var gemini31Pro = append("gemini-3-1-pro-series");
  var gemini3Pro = append("gemini-3-pro");
  var imageReset = (gemini31Pro && gemini31Pro.resetTime) || (gemini3Pro && gemini3Pro.resetTime) || null;
  append("gemini-2-5-flash");
  append("gemini-2-5-flash-lite");
  append("gemini-2-5-cu");
  append("gemini-3-flash");
  append("gemini-image", imageReset);
  return rows;
}

function parseAntigravityGroup(group, models, resetOverride) {
  var entries = [];
  group.identifiers.forEach(function (identifier) {
    var match = antigravityModelEntry(models, identifier);
    if (!match) return;
    var quota = match.entry.quotaInfo || match.entry.quota_info || {};
    var remaining = fractionOrNull(quota.remainingFraction !== undefined ? quota.remainingFraction :
      (quota.remaining_fraction !== undefined ? quota.remaining_fraction : quota.remaining));
    var resetTime = clean(quota.resetTime || quota.reset_time || "");
    if (remaining === null && resetTime) remaining = 0;
    if (remaining === null) return;
    entries.push({
      id: match.id,
      remaining: Math.max(0, Math.min(1, remaining)),
      resetTime: resetTime,
      displayName: clean(match.entry.displayName || match.entry.display_name || "")
    });
  });
  if (!entries.length) return null;
  var remainingFraction = Math.min.apply(null, entries.map(function (item) { return item.remaining; }));
  var resetTime = resetOverride || entries.map(function (item) { return item.resetTime; }).filter(Boolean)[0] || "";
  var displayName = entries.map(function (item) { return item.displayName; }).filter(Boolean)[0] || "";
  var label = group.labelFromModel && displayName ? displayName : group.label;
  return {
    resetTime: resetTime,
    row: {
      id: group.id,
      label: label,
      remaining: Math.round(remainingFraction * 100),
      resetLabel: formatResetTime(resetTime)
    }
  };
}

function antigravityModelEntry(models, identifier) {
  if (models[identifier] && typeof models[identifier] === "object") {
    return { id: identifier, entry: models[identifier] };
  }
  var keys = Object.keys(models);
  var target = identifier.toLowerCase();
  for (var i = 0; i < keys.length; i++) {
    var entry = models[keys[i]];
    if (!entry || typeof entry !== "object") continue;
    var displayName = clean(entry.displayName || entry.display_name || "").toLowerCase();
    if (displayName === target) return { id: keys[i], entry: entry };
  }
  return null;
}

function findRateLimit(value) {
  var found = findObjectByName(value, "rate_limit");
  if (found) return found;
  return findObjectByName(value, "rateLimit");
}

function findObjectByName(value, target) {
  if (!value || typeof value !== "object") return null;
  if (value[target] && typeof value[target] === "object") return value[target];
  if (Array.isArray(value)) {
    for (var i = 0; i < value.length; i++) {
      var arrayFound = findObjectByName(value[i], target);
      if (arrayFound) return arrayFound;
    }
  } else {
    var keys = Object.keys(value);
    for (var j = 0; j < keys.length; j++) {
      var found = findObjectByName(value[keys[j]], target);
      if (found) return found;
    }
  }
  return null;
}

function pickWindows(first, second) {
  var candidates = [first, second].filter(function (x) { return !!x; });
  var primary = null;
  var weekly = null;
  candidates.forEach(function (candidate) {
    var duration = Number(candidate.limit_window_seconds || candidate.limitWindowSeconds || 0);
    if (duration === 18000 && !primary) primary = candidate;
    if (duration === 604800 && !weekly) weekly = candidate;
  });
  return { primary: primary || first, weekly: weekly || second };
}

function remainingPercent(window, rate) {
  if (!window) return null;
  var used = numberOrNull(window.used_percent !== undefined ? window.used_percent : window.usedPercent);
  if (used === null && ((rate.limit_reached || rate.limitReached) || rate.allowed === false) && resetSeconds(window) !== null) {
    used = 100;
  }
  if (used === null) return null;
  return Math.max(0, Math.min(100, 100 - used));
}

function antigravityBalanceProgress(amount, minimum) {
  if (!isNumber(amount)) return null;
  if (!isNumber(minimum) || minimum <= 0) return amount > 0 ? 100 : 0;
  return Math.max(0, Math.min(100, (amount / minimum) * 100));
}

function antigravityBalanceUsable(amount, minimum) {
  if (!isNumber(amount)) return null;
  if (!isNumber(minimum) || minimum <= 0) return amount > 0;
  return amount >= minimum;
}

function formatResetTime(value) {
  if (!value) return "-";
  var date = new Date(value);
  if (!Number.isFinite(date.getTime())) return "-";
  function two(n) { return n < 10 ? "0" + n : String(n); }
  return two(date.getMonth() + 1) + "-" + two(date.getDate()) + " " +
    two(date.getHours()) + ":" + two(date.getMinutes());
}

function resetSeconds(window) {
  if (!window) return null;
  var seconds = numberOrNull(window.reset_after_seconds !== undefined ? window.reset_after_seconds : window.resetAfterSeconds);
  if (seconds !== null) return seconds;
  var at = numberOrNull(window.reset_at !== undefined ? window.reset_at : window.resetAt);
  if (at !== null) return Math.max(0, at - Math.floor(Date.now() / 1000));
  return null;
}

function buildSnapshot(accounts) {
  var primaryValues = accounts.map(function (a) { return a.primaryRemaining; }).filter(isNumber);
  var weeklyValues = accounts.map(function (a) { return a.weeklyRemaining; }).filter(isNumber);
  var quotaAccounts = accounts.filter(function (account) {
    return isNumber(account.primaryRemaining) || (account.quotaRows && account.quotaRows.length > 0);
  }).length;
  var now = new Date();
  return {
    accounts: accounts.sort(function (a, b) { return a.name.localeCompare(b.name); }),
    totalAccounts: accounts.length,
    quotaAccounts: quotaAccounts,
    primaryAverage: average(primaryValues),
    weeklyAverage: average(weeklyValues),
    updatedAt: now,
    relativeUpdate: "just now"
  };
}

function managementURL(path) {
  var base = normalizedBaseURL();
  return base.replace(/\/+$/, "") + "/" + String(path).replace(/^\/+/, "");
}

function normalizedBaseURL() {
  var base = clean(settings.baseURL || "http://127.0.0.1:8317");
  if (base.indexOf("://") < 0) base = "https://" + base;
  base = base.replace(/\/management\.html.*$/i, "");
  base = base.replace(/\/v0\/management\/?$/i, "");
  return base.replace(/\/+$/, "");
}

function isConfigured() {
  return clean(settings.baseURL) && clean(settings.managementKey);
}

function settingsPath() {
  var fm = $.NSFileManager.defaultManager;
  var urls = fm.URLsForDirectoryInDomains($.NSApplicationSupportDirectory, $.NSUserDomainMask);
  var dir = ObjC.unwrap(urls.objectAtIndex(0).path) + "/CPAQuotaBar";
  app.doShellScript("/bin/mkdir -p " + shellQuote(dir));
  return dir + "/settings.json";
}

function loadSettings() {
  var defaults = { baseURL: "http://127.0.0.1:8317", managementKey: "", refreshIntervalSeconds: 300 };
  try {
    var path = settingsPath();
    var data = $.NSData.dataWithContentsOfFile(path);
    if (!data) {
      defaults.managementKey = readKeychain();
      return defaults;
    }
    var text = ObjC.unwrap($.NSString.alloc.initWithDataEncoding(data, $.NSUTF8StringEncoding));
    var parsed = JSON.parse(text);
    return {
      baseURL: parsed.baseURL || defaults.baseURL,
      managementKey: readKeychain() || parsed.managementKey || "",
      refreshIntervalSeconds: parsed.refreshIntervalSeconds || defaults.refreshIntervalSeconds
    };
  } catch (error) {
    defaults.managementKey = readKeychain();
    return defaults;
  }
}

function saveSettings(value) {
  saveKeychain(value.managementKey || "");
  var persisted = {
    baseURL: value.baseURL || "http://127.0.0.1:8317",
    refreshIntervalSeconds: value.refreshIntervalSeconds || 300
  };
  var text = $(JSON.stringify(persisted, null, 2));
  text.writeToFileAtomicallyEncodingError(settingsPath(), true, $.NSUTF8StringEncoding, null);
}

function readKeychain() {
  try {
    return clean(app.doShellScript("/usr/bin/security find-generic-password -s " +
      shellQuote(keychainService) + " -a " + shellQuote(keychainAccount) + " -w"));
  } catch (error) {
    return "";
  }
}

function saveKeychain(value) {
  try {
    app.doShellScript("/usr/bin/security delete-generic-password -s " +
      shellQuote(keychainService) + " -a " + shellQuote(keychainAccount) + " >/dev/null 2>&1 || true");
  } catch (error) {}
  if (!clean(value)) return;
  app.doShellScript("/usr/bin/security add-generic-password -U -s " +
    shellQuote(keychainService) + " -a " + shellQuote(keychainAccount) +
    " -w " + shellQuote(value) + " >/dev/null");
}

function showError(message) {
  var alert = $.NSAlert.alloc.init;
  alert.messageText = "Couldn’t refresh";
  alert.informativeText = String(message);
  alert.addButtonWithTitle("OK");
  nsApp.activateIgnoringOtherApps(true);
  alert.runModal;
}

function shellQuote(value) {
  return "'" + String(value).replace(/'/g, "'\\''") + "'";
}

function clean(value) {
  return String(value || "").replace(/^\s+|\s+$/g, "");
}

function cleanName(value) {
  var name = clean(value);
  name = name.replace(/\.json$/i, "");
  name = name.replace(/^codex-/i, "");
  return name;
}

function numberOrNull(value) {
  var number = Number(value);
  return Number.isFinite(number) ? number : null;
}

function integerOrNull(value) {
  var number = numberOrNull(value);
  return number === null ? null : Math.floor(number);
}

function fractionOrNull(value) {
  var number = numberOrNull(value);
  if (number !== null) return number;
  var text = clean(value);
  if (text.slice(-1) === "%") {
    var percent = numberOrNull(text.slice(0, -1));
    if (percent !== null) return percent / 100;
  }
  return null;
}

function centsValue(value) {
  if (value && typeof value === "object" && !Array.isArray(value)) {
    return numberOrNull(value.val);
  }
  return numberOrNull(value);
}

function money(cents) {
  return isNumber(cents) ? "$" + (cents / 100).toFixed(2) : "--";
}

function moneyPair(used, limit) {
  var usedCents = centsValue(used);
  var limitCents = centsValue(limit);
  if (usedCents === null && limitCents === null) return "";
  if (limitCents === null) return money(usedCents);
  return money(usedCents) + " / " + money(limitCents);
}

function durationLabel(seconds) {
  if (!isNumber(seconds) || seconds <= 0) return "now";
  var minutes = Math.ceil(seconds / 60);
  if (minutes < 60) return String(minutes) + "m";
  var hours = Math.floor(minutes / 60);
  var rem = minutes % 60;
  if (hours < 24) return rem ? String(hours) + "h " + String(rem) + "m" : String(hours) + "h";
  var days = Math.floor(hours / 24);
  var remHours = hours % 24;
  return remHours ? String(days) + "d " + String(remHours) + "h" : String(days) + "d";
}

function isNumber(value) {
  return typeof value === "number" && Number.isFinite(value);
}

function average(values) {
  if (!values.length) return null;
  return values.reduce(function (sum, value) { return sum + value; }, 0) / values.length;
}

function formatPercent(value) {
  if (!isNumber(value)) return "--";
  if (value >= 99.95) return "100%";
  if (value < 10) return Math.max(0, value).toFixed(1) + "%";
  return Math.round(Math.max(0, value)) + "%";
}

function formatCredits(value) {
  if (!isNumber(value)) return "--";
  var amount = Math.max(0, value);
  if (amount >= 1000000) {
    var millions = amount / 1000000;
    return (millions >= 10 ? millions.toFixed(0) : millions.toFixed(1)) + "M";
  }
  if (amount >= 1000) {
    var thousands = amount / 1000;
    return (thousands >= 10 ? thousands.toFixed(0) : thousands.toFixed(1)) + "K";
  }
  if (Math.floor(amount) === amount) return amount.toFixed(0);
  return amount < 10 ? amount.toFixed(1) : amount.toFixed(0);
}

function statusGlyph(account) {
  if (account.error) return "✕";
  if (account.disabled) return "—";
  if (account.quotaRows && account.quotaRows.length) {
    var values = account.quotaRows.map(function (row) { return row.remaining; }).filter(isNumber);
    if (!values.length) return "●";
    var lowest = Math.min.apply(null, values);
    if (lowest <= 15) return "◯";
    if (lowest <= 35) return "◐";
    return "●";
  }
  var p = account.primaryRemaining;
  if (!isNumber(p)) return "·";
  if (p <= 15) return "◯";
  if (p <= 35) return "◐";
  return "●";
}

function trimForMenu(value, maxLength) {
  var text = String(value || "");
  if (text.length <= maxLength) return text;
  return text.slice(0, Math.max(0, maxLength - 1)) + "…";
}

function padRight(text, width) {
  text = String(text || "");
  while (text.length < width) text += " ";
  return text;
}

function padLeft(text, width) {
  text = String(text || "");
  while (text.length < width) text = " " + text;
  return text;
}

function relativeUpdateString(date) {
  if (!(date instanceof Date)) return "moments ago";
  var diff = Math.floor((Date.now() - date.getTime()) / 1000);
  if (diff < 5) return "just now";
  if (diff < 60) return diff + "s ago";
  if (diff < 3600) return Math.floor(diff / 60) + "m ago";
  if (diff < 86400) return Math.floor(diff / 3600) + "h ago";
  return Math.floor(diff / 86400) + "d ago";
}
