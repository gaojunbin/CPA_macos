ObjC.import("Cocoa");
ObjC.import("Foundation");

var app = Application.currentApplication();
app.includeStandardAdditions = true;

var nsApp = $.NSApplication.sharedApplication;
var statusItem = null;
var statusMenu = null;
var delegate = null;
var refreshTimer = null;
var keychainService = "local.cpa.quota-bar";
var keychainAccount = "management-key";
var settings = loadSettings();
var snapshot = null;
var refreshing = false;
var lastError = "";
var started = false;

ObjC.registerSubclass({
  name: "CPAQuotaBarDelegate",
  protocols: ["NSApplicationDelegate"],
  methods: {
    "applicationDidFinishLaunching:": {
      types: ["void", ["id"]],
      implementation: function () {
        startApp();
      }
    },
    "refresh:": {
      types: ["void", ["id"]],
      implementation: function () {
        refreshQuotas(true);
      }
    },
    "settings:": {
      types: ["void", ["id"]],
      implementation: function () {
        showSettings();
      }
    },
    "quit:": {
      types: ["void", ["id"]],
      implementation: function () {
        nsApp.terminate(null);
      }
    },
    "timerRefresh:": {
      types: ["void", ["id"]],
      implementation: function () {
        refreshQuotas(false);
      }
    }
  }
});

delegate = $.CPAQuotaBarDelegate.alloc.init;
nsApp.delegate = delegate;
nsApp.setActivationPolicy($.NSApplicationActivationPolicyAccessory);
startApp();
nsApp.run;

function startApp() {
  if (started) return;
  started = true;
  setupStatusBar();
  if (!isConfigured()) {
    updateMenu();
    showSettings();
  } else {
    refreshQuotas(false);
    restartTimer();
  }
}

function setupStatusBar() {
  statusItem = $.NSStatusBar.systemStatusBar.statusItemWithLength($.NSVariableStatusItemLength);
  var button = statusItem.button;
  button.title = "";
  var image = $.NSImage.imageWithSystemSymbolNameAccessibilityDescription("gauge.with.dots.needle.50percent", "CLIProxyAPI quota");
  if (image) {
    button.image = image;
    button.imagePosition = $.NSImageLeft;
  }
  statusMenu = $.NSMenu.alloc.initWithTitle("Pool");
  statusItem.menu = statusMenu;
  updateMenu();
}

function updateStatusTitle() {
  if (!statusItem) return;
  var button = statusItem.button;
  if (!isConfigured()) {
    button.title = "";
    return;
  }
  if (refreshing && !snapshot) {
    button.title = "  ⋯";
  } else if (lastError && !snapshot) {
    button.title = "  !";
  } else if (snapshot && typeof snapshot.primaryAverage === "number") {
    button.title = "  " + formatPercent(snapshot.primaryAverage);
  } else {
    button.title = "";
  }
}

function updateMenu() {
  if (!statusMenu) return;
  statusMenu.removeAllItems;

  if (snapshot) {
    snapshot.relativeUpdate = relativeUpdateString(snapshot.updatedAt);
  }

  if (!isConfigured()) {
    addDisabledItem("Not configured");
    statusMenu.addItem($.NSMenuItem.separatorItem);
    addDisabledItem("Open Settings to connect.");
  } else if (lastError && !snapshot) {
    addDisabledItem(trimForMenu(lastError, 72));
  } else if (snapshot) {
    addDisabledItem(formatPercent(snapshot.primaryAverage) + " · 5h    " +
      formatPercent(snapshot.weeklyAverage) + " · 7d    " +
      snapshot.quotaAccounts + "/" + snapshot.totalAccounts + " accts");
    addDisabledItem("Updated " + snapshot.relativeUpdate);
    statusMenu.addItem($.NSMenuItem.separatorItem);

    if (snapshot.accounts.length === 0) {
      addDisabledItem("No Codex accounts");
    } else {
      snapshot.accounts.forEach(function (account) {
        var p5 = account.primaryRemaining;
        var p7 = account.weeklyRemaining;
        var dot = statusGlyph(account);
        var name = trimForMenu(account.name, 26);
        var title = dot + "  " + padRight(name, 26) + "   " +
          padLeft(formatPercent(p5), 5) + "   " +
          padLeft(formatPercent(p7), 5);
        if (account.plan) title += "   " + account.plan;
        addDisabledItem(title);
        if (account.error) addDisabledItem("     " + trimForMenu(account.error, 72));
      });
    }
    if (lastError) {
      statusMenu.addItem($.NSMenuItem.separatorItem);
      addDisabledItem(trimForMenu(lastError, 72));
    }
  } else {
    addDisabledItem(refreshing ? "Refreshing…" : "No data");
  }

  statusMenu.addItem($.NSMenuItem.separatorItem);
  addActionItem(refreshing ? "Refreshing…" : "Refresh", "refresh:", !refreshing && isConfigured());
  addActionItem("Settings…", "settings:", true);
  addActionItem("Quit", "quit:", true);
  updateStatusTitle();
}

function addDisabledItem(title) {
  var item = $.NSMenuItem.alloc.initWithTitleActionKeyEquivalent(String(title), null, "");
  item.enabled = false;
  statusMenu.addItem(item);
}

function addActionItem(title, actionName, enabled) {
  var item = $.NSMenuItem.alloc.initWithTitleActionKeyEquivalent(String(title), $.NSSelectorFromString(actionName), "");
  item.target = delegate;
  item.enabled = enabled;
  statusMenu.addItem(item);
}

function showSettings() {
  var alert = $.NSAlert.alloc.init;
  alert.messageText = "CLIProxyAPI";
  alert.informativeText = "Where to reach your pool.";
  alert.addButtonWithTitle("Save");
  alert.addButtonWithTitle("Cancel");

  var stack = $.NSStackView.alloc.initWithFrame($.NSMakeRect(0, 0, 420, 190));
  stack.orientation = $.NSUserInterfaceLayoutOrientationVertical;
  stack.spacing = 8;

  var urlField = $.NSTextField.alloc.initWithFrame($.NSMakeRect(0, 0, 420, 28));
  urlField.placeholderString = "https://your-vps.example.com";
  urlField.stringValue = settings.baseURL || "http://127.0.0.1:8317";

  var keyField = $.NSSecureTextField.alloc.initWithFrame($.NSMakeRect(0, 0, 420, 28));
  keyField.placeholderString = "Management password";
  keyField.stringValue = settings.managementKey || "";

  var intervalField = $.NSTextField.alloc.initWithFrame($.NSMakeRect(0, 0, 420, 28));
  intervalField.placeholderString = "5";
  intervalField.stringValue = String(Math.max(1, Math.round((settings.refreshIntervalSeconds || 300) / 60)));

  stack.addArrangedSubview(labelField("Endpoint"));
  stack.addArrangedSubview(urlField);
  stack.addArrangedSubview(labelField("Password"));
  stack.addArrangedSubview(keyField);
  stack.addArrangedSubview(labelField("Refresh (minutes)"));
  stack.addArrangedSubview(intervalField);
  alert.accessoryView = stack;

  nsApp.activateIgnoringOtherApps(true);
  var result = alert.runModal;
  if (result !== $.NSAlertFirstButtonReturn) return;

  var minutes = parseFloat(ObjC.unwrap(intervalField.stringValue)) || 5;
  settings = {
    baseURL: ObjC.unwrap(urlField.stringValue),
    managementKey: ObjC.unwrap(keyField.stringValue),
    refreshIntervalSeconds: Math.max(60, Math.min(86400, minutes * 60))
  };
  saveSettings(settings);
  lastError = "";
  updateMenu();
  refreshQuotas(true);
  restartTimer();
}

function labelField(text) {
  var field = $.NSTextField.labelWithString(String(text));
  field.font = $.NSFont.systemFontOfSize(11);
  field.textColor = $.NSColor.secondaryLabelColor;
  return field;
}

function restartTimer() {
  if (refreshTimer) {
    refreshTimer.invalidate;
    refreshTimer = null;
  }
  if (!isConfigured()) return;
  refreshTimer = $.NSTimer.scheduledTimerWithTimeIntervalTargetSelectorUserInfoRepeats(
    settings.refreshIntervalSeconds || 300,
    delegate,
    $.NSSelectorFromString("timerRefresh:"),
    null,
    true
  );
}

function refreshQuotas(showErrors) {
  if (refreshing || !isConfigured()) {
    updateMenu();
    return;
  }
  refreshing = true;
  lastError = "";
  updateMenu();

  try {
    var authFiles = fetchAuthFiles().filter(function (auth) {
      return auth.isCodexLike;
    });
    var accounts = authFiles.map(function (auth) {
      return fetchAccountQuota(auth);
    });
    snapshot = buildSnapshot(accounts);
  } catch (error) {
    lastError = String(error);
    if (showErrors) showError(lastError);
  }

  refreshing = false;
  updateMenu();
}

function fetchAuthFiles() {
  var raw = curlJSON("GET", managementURL("/v0/management/auth-files"), null);
  var payload = JSON.parse(raw || "{}");
  var files = Array.isArray(payload.files) ? payload.files : [];
  return files.map(normalizeAuthFile);
}

function fetchAccountQuota(auth) {
  if (!auth.authIndex) {
    auth.error = "missing auth_index";
    return auth;
  }
  if (auth.disabled) {
    auth.error = "";
    return auth;
  }

  var headers = {
    "Authorization": "Bearer $TOKEN$",
    "Accept": "application/json",
    "Content-Type": "application/json",
    "User-Agent": "codex_cli_rs/0.76.0 (Macintosh; arm64) CPAQuotaBar/1.0"
  };
  if (auth.accountID) headers["ChatGPT-Account-Id"] = auth.accountID;

  var payload = {
    auth_index: auth.authIndex,
    method: "GET",
    url: "https://chatgpt.com/backend-api/wham/usage",
    header: headers
  };

  try {
    var raw = curlJSON("POST", managementURL("/v0/management/api-call"), JSON.stringify(payload));
    var envelope = JSON.parse(raw || "{}");
    var body = typeof envelope.body === "string" ? envelope.body : JSON.stringify(envelope.body || {});
    var usage = parseUsage(body);
    auth.primaryRemaining = usage.primaryRemaining;
    auth.weeklyRemaining = usage.weeklyRemaining;
    auth.primaryReset = usage.primaryReset;
    auth.weeklyReset = usage.weeklyReset;
    auth.plan = usage.plan || auth.plan;
    auth.error = "";
  } catch (error) {
    auth.error = String(error);
  }
  return auth;
}

function curlJSON(method, url, body) {
  var command = "/usr/bin/curl -sS --fail-with-body --max-time 45 " +
    "-X " + shellQuote(method) + " " +
    "-H " + shellQuote("Authorization: Bearer " + settings.managementKey) + " " +
    "-H " + shellQuote("Content-Type: application/json") + " ";
  if (body !== null && body !== undefined) {
    command += "--data-binary " + shellQuote(body) + " ";
  }
  command += shellQuote(url);
  return app.doShellScript(command);
}

function normalizeAuthFile(file) {
  var provider = clean(file.provider || file.type || "");
  var idToken = file.id_token || {};
  var name = clean(file.label || file.email || file.account || cleanName(file.name) || file.id || "unknown");
  return {
    id: clean(file.id || file.name || name),
    name: name,
    authIndex: clean(file.auth_index || file.authIndex || ""),
    provider: provider,
    isCodexLike: provider === "codex" || provider.indexOf("openai") >= 0,
    accountID: clean(idToken.chatgpt_account_id || file.chatgpt_account_id || file.account_id || ""),
    plan: clean(idToken.plan_type || file.plan_type || file.plan || ""),
    disabled: !!file.disabled || String(file.status || "").toLowerCase() === "disabled",
    primaryRemaining: null,
    weeklyRemaining: null,
    primaryReset: null,
    weeklyReset: null,
    error: ""
  };
}

function parseUsage(body) {
  var payload = JSON.parse(body || "{}");
  var rate = findRateLimit(payload);
  if (!rate) throw new Error("quota payload missing rate_limit");
  var primary = rate.primary_window || rate.primaryWindow || null;
  var secondary = rate.secondary_window || rate.secondaryWindow || null;
  var windows = pickWindows(primary, secondary);
  return {
    plan: clean(payload.plan_type || payload.planType || (payload.account_plan || {}).plan_type || ""),
    primaryRemaining: remainingPercent(windows.primary, rate),
    weeklyRemaining: remainingPercent(windows.weekly, rate),
    primaryReset: resetSeconds(windows.primary),
    weeklyReset: resetSeconds(windows.weekly)
  };
}

function findRateLimit(value) {
  if (!value || typeof value !== "object") return null;
  if (value.rate_limit || value.rateLimit) return value.rate_limit || value.rateLimit;
  if (Array.isArray(value)) {
    for (var i = 0; i < value.length; i++) {
      var arrayFound = findRateLimit(value[i]);
      if (arrayFound) return arrayFound;
    }
  } else {
    var keys = Object.keys(value);
    for (var j = 0; j < keys.length; j++) {
      var found = findRateLimit(value[keys[j]]);
      if (found) return found;
    }
  }
  return null;
}

function pickWindows(first, second) {
  var candidates = [first, second].filter(function (x) { return !!x; });
  var primary = null;
  var weekly = null;
  candidates.forEach(function (candidate) {
    var duration = Number(candidate.limit_window_seconds || candidate.limitWindowSeconds || 0);
    if (duration === 18000 && !primary) primary = candidate;
    if (duration === 604800 && !weekly) weekly = candidate;
  });
  return { primary: primary || first, weekly: weekly || second };
}

function remainingPercent(window, rate) {
  if (!window) return null;
  var used = numberOrNull(window.used_percent !== undefined ? window.used_percent : window.usedPercent);
  if (used === null && ((rate.limit_reached || rate.limitReached) || rate.allowed === false) && resetSeconds(window) !== null) {
    used = 100;
  }
  if (used === null) return null;
  return Math.max(0, Math.min(100, 100 - used));
}

function resetSeconds(window) {
  if (!window) return null;
  var seconds = numberOrNull(window.reset_after_seconds !== undefined ? window.reset_after_seconds : window.resetAfterSeconds);
  if (seconds !== null) return seconds;
  var at = numberOrNull(window.reset_at !== undefined ? window.reset_at : window.resetAt);
  if (at !== null) return Math.max(0, at - Math.floor(Date.now() / 1000));
  return null;
}

function buildSnapshot(accounts) {
  var primaryValues = accounts.map(function (a) { return a.primaryRemaining; }).filter(isNumber);
  var weeklyValues = accounts.map(function (a) { return a.weeklyRemaining; }).filter(isNumber);
  var now = new Date();
  return {
    accounts: accounts.sort(function (a, b) { return a.name.localeCompare(b.name); }),
    totalAccounts: accounts.length,
    quotaAccounts: primaryValues.length,
    primaryAverage: average(primaryValues),
    weeklyAverage: average(weeklyValues),
    updatedAt: now,
    relativeUpdate: "just now"
  };
}

function managementURL(path) {
  var base = normalizedBaseURL();
  return base.replace(/\/+$/, "") + "/" + String(path).replace(/^\/+/, "");
}

function normalizedBaseURL() {
  var base = clean(settings.baseURL || "http://127.0.0.1:8317");
  if (base.indexOf("://") < 0) base = "https://" + base;
  base = base.replace(/\/management\.html.*$/i, "");
  base = base.replace(/\/v0\/management\/?$/i, "");
  return base.replace(/\/+$/, "");
}

function isConfigured() {
  return clean(settings.baseURL) && clean(settings.managementKey);
}

function settingsPath() {
  var fm = $.NSFileManager.defaultManager;
  var urls = fm.URLsForDirectoryInDomains($.NSApplicationSupportDirectory, $.NSUserDomainMask);
  var dir = ObjC.unwrap(urls.objectAtIndex(0).path) + "/CPAQuotaBar";
  app.doShellScript("/bin/mkdir -p " + shellQuote(dir));
  return dir + "/settings.json";
}

function loadSettings() {
  var defaults = { baseURL: "http://127.0.0.1:8317", managementKey: "", refreshIntervalSeconds: 300 };
  try {
    var path = settingsPath();
    var data = $.NSData.dataWithContentsOfFile(path);
    if (!data) {
      defaults.managementKey = readKeychain();
      return defaults;
    }
    var text = ObjC.unwrap($.NSString.alloc.initWithDataEncoding(data, $.NSUTF8StringEncoding));
    var parsed = JSON.parse(text);
    return {
      baseURL: parsed.baseURL || defaults.baseURL,
      managementKey: readKeychain() || parsed.managementKey || "",
      refreshIntervalSeconds: parsed.refreshIntervalSeconds || defaults.refreshIntervalSeconds
    };
  } catch (error) {
    defaults.managementKey = readKeychain();
    return defaults;
  }
}

function saveSettings(value) {
  saveKeychain(value.managementKey || "");
  var persisted = {
    baseURL: value.baseURL || "http://127.0.0.1:8317",
    refreshIntervalSeconds: value.refreshIntervalSeconds || 300
  };
  var text = $(JSON.stringify(persisted, null, 2));
  text.writeToFileAtomicallyEncodingError(settingsPath(), true, $.NSUTF8StringEncoding, null);
}

function readKeychain() {
  try {
    return clean(app.doShellScript("/usr/bin/security find-generic-password -s " +
      shellQuote(keychainService) + " -a " + shellQuote(keychainAccount) + " -w"));
  } catch (error) {
    return "";
  }
}

function saveKeychain(value) {
  try {
    app.doShellScript("/usr/bin/security delete-generic-password -s " +
      shellQuote(keychainService) + " -a " + shellQuote(keychainAccount) + " >/dev/null 2>&1 || true");
  } catch (error) {}
  if (!clean(value)) return;
  app.doShellScript("/usr/bin/security add-generic-password -U -s " +
    shellQuote(keychainService) + " -a " + shellQuote(keychainAccount) +
    " -w " + shellQuote(value) + " >/dev/null");
}

function showError(message) {
  var alert = $.NSAlert.alloc.init;
  alert.messageText = "Couldn’t refresh";
  alert.informativeText = String(message);
  alert.addButtonWithTitle("OK");
  nsApp.activateIgnoringOtherApps(true);
  alert.runModal;
}

function shellQuote(value) {
  return "'" + String(value).replace(/'/g, "'\\''") + "'";
}

function clean(value) {
  return String(value || "").replace(/^\s+|\s+$/g, "");
}

function cleanName(value) {
  var name = clean(value);
  name = name.replace(/\.json$/i, "");
  name = name.replace(/^codex-/i, "");
  return name;
}

function numberOrNull(value) {
  var number = Number(value);
  return Number.isFinite(number) ? number : null;
}

function isNumber(value) {
  return typeof value === "number" && Number.isFinite(value);
}

function average(values) {
  if (!values.length) return null;
  return values.reduce(function (sum, value) { return sum + value; }, 0) / values.length;
}

function formatPercent(value) {
  if (!isNumber(value)) return "--";
  if (value >= 99.95) return "100%";
  if (value < 10) return Math.max(0, value).toFixed(1) + "%";
  return Math.round(Math.max(0, value)) + "%";
}

function statusGlyph(account) {
  if (account.error) return "✕";
  if (account.disabled) return "—";
  var p = account.primaryRemaining;
  if (!isNumber(p)) return "·";
  if (p <= 15) return "◯";
  if (p <= 35) return "◐";
  return "●";
}

function trimForMenu(value, maxLength) {
  var text = String(value || "");
  if (text.length <= maxLength) return text;
  return text.slice(0, Math.max(0, maxLength - 1)) + "…";
}

function padRight(text, width) {
  text = String(text || "");
  while (text.length < width) text += " ";
  return text;
}

function padLeft(text, width) {
  text = String(text || "");
  while (text.length < width) text = " " + text;
  return text;
}

function relativeUpdateString(date) {
  if (!(date instanceof Date)) return "moments ago";
  var diff = Math.floor((Date.now() - date.getTime()) / 1000);
  if (diff < 5) return "just now";
  if (diff < 60) return diff + "s ago";
  if (diff < 3600) return Math.floor(diff / 60) + "m ago";
  if (diff < 86400) return Math.floor(diff / 3600) + "h ago";
  return Math.floor(diff / 86400) + "d ago";
}
